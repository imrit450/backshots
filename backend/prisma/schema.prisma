generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Host {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  displayName     String    @map("display_name")
  role            String    @default("user")
  canCreateEvents Boolean   @default(false) @map("can_create_events")
  plan            String    @default("free")
  planExpiresAt   DateTime? @map("plan_expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  events          Event[]
  guestSessions   GuestSession[]

  @@map("hosts")
}

model Event {
  id                  String         @id @default(uuid())
  hostId              String         @map("host_id")
  title               String
  location            String?
  iconUrl             String?        @map("icon_url")
  startDatetime       DateTime       @map("start_datetime")
  timezone            String         @default("UTC")
  revealDelayHours    Int            @default(0) @map("reveal_delay_hours")
  uploadCutoffHours   Int            @default(24) @map("upload_cutoff_hours")
  maxPhotosPerGuest   Int            @default(20) @map("max_photos_per_guest")
  maxPhotosTotal      Int            @default(500) @map("max_photos_total")
  maxStorageMb        Int            @default(500) @map("max_storage_mb")
  guestGalleryEnabled Boolean        @default(true) @map("guest_gallery_enabled")
  filtersEnabled      Boolean        @default(false) @map("filters_enabled")
  allowedFilters      String         @default("[]") @map("allowed_filters")
  moderationMode      String         @default("AUTO") @map("moderation_mode")
  theme               String         @default("classic") @map("theme")
  eventCode           String         @unique @map("event_code")
  isActive            Boolean        @default(true) @map("is_active")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  host          Host           @relation(fields: [hostId], references: [id])
  guestSessions GuestSession[]
  photos        Photo[]
  exports       Export[]
  videos        Video[]

  @@map("events")
}

model GuestSession {
  id           String   @id @default(uuid())
  eventId      String   @map("event_id")
  hostId       String?  @map("host_id")
  deviceId     String?  @map("device_id")
  displayName  String   @map("display_name")
  phoneNumber  String?  @map("phone_number")
  token        String   @unique
  photoCount   Int      @default(0) @map("photo_count")
  lastUploadAt DateTime? @map("last_upload_at")
  createdAt    DateTime @default(now()) @map("created_at")

  event  Event   @relation(fields: [eventId], references: [id])
  host   Host?   @relation(fields: [hostId], references: [id])
  photos Photo[]
  videos Video[]

  @@unique([eventId, deviceId])
  @@map("guest_sessions")
}

model Photo {
  id             String   @id @default(uuid())
  eventId        String   @map("event_id")
  guestSessionId String   @map("guest_session_id")
  title          String?
  description    String?
  status         String   @default("PENDING")
  hidden         Boolean  @default(false)
  capturedAt     DateTime @default(now()) @map("captured_at")
  revealAt       DateTime @map("reveal_at")
  originalUrl    String?  @map("original_url")
  largeUrl       String?  @map("large_url")
  thumbUrl       String?  @map("thumb_url")
  filterApplied  String?  @map("filter_applied")
  fileSize       Int      @default(0) @map("file_size")
  qualityScore   Float?   @map("quality_score")
  qualityIssues  String?  @map("quality_issues")
  createdAt      DateTime @default(now()) @map("created_at")

  event        Event        @relation(fields: [eventId], references: [id])
  guestSession GuestSession @relation(fields: [guestSessionId], references: [id])

  @@map("photos")
}

model Export {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  status    String   @default("PENDING")
  fileUrl   String?  @map("file_url")
  photoCount Int     @default(0) @map("photo_count")
  createdAt DateTime @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  event Event @relation(fields: [eventId], references: [id])

  @@map("exports")
}

model Video {
  id             String   @id @default(uuid())
  eventId        String   @map("event_id")
  guestSessionId String   @map("guest_session_id")
  title          String?
  description    String?
  status         String   @default("PENDING")
  hidden         Boolean  @default(false)
  capturedAt     DateTime @default(now()) @map("captured_at")
  url            String   @map("url")
  durationSec    Int      @map("duration_sec")
  fileSize       Int      @default(0) @map("file_size")
  createdAt      DateTime @default(now()) @map("created_at")

  event        Event        @relation(fields: [eventId], references: [id])
  guestSession GuestSession @relation(fields: [guestSessionId], references: [id])

  @@map("videos")
}

model SystemConfig {
  id               Int      @id @default(1)
  storageType      String   @default("filesystem") @map("storage_type")
  s3Bucket         String?  @map("s3_bucket")
  s3Region         String?  @map("s3_region")
  s3Endpoint       String?  @map("s3_endpoint")
  s3AccessKeyId    String?  @map("s3_access_key_id")
  s3SecretAccessKey String? @map("s3_secret_access_key")
  s3PublicUrl      String?  @map("s3_public_url")
  s3ForcePathStyle Boolean  @default(false) @map("s3_force_path_style")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}
