# ── Database ──────────────────────────────────────
# Development (SQLite):
DATABASE_URL="file:./lumora.db"
# Production (PostgreSQL):
# DATABASE_URL="postgresql://lumora:STRONG_PASSWORD@db:5432/lumora?schema=public"

# ── Auth ──────────────────────────────────────────
JWT_SECRET="CHANGE-ME-to-a-random-64-char-string"

# ── Clerk (optional — keyless mode is used when these are absent) ─────────
# After clicking "Configure your application" in the Clerk widget, paste the
# keys from your Clerk Dashboard here.
# CLERK_SECRET_KEY=sk_live_...
# CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Server ────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
BASE_URL="http://localhost:3001"

# ── Storage ───────────────────────────────────────
STORAGE_TYPE=filesystem
UPLOAD_DIR="../uploads"
EXPORT_DIR="../exports"

# S3-compatible storage (uncomment for production)
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_ENDPOINT=               # optional: for R2, MinIO, DigitalOcean Spaces
# S3_FORCE_PATH_STYLE=false  # set true for MinIO
